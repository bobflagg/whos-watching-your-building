# NYC Open Data app token — register at https://data.cityofnewyork.us/profile/app_tokens
NYC_OPEN_DATA_APP_TOKEN=your_app_token_here

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Tavily Search API key — https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Neo4j connection (local Neo4j Desktop defaults shown)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# How many months of historical data to pull from NYC Open Data (default: 6)
LOOKBACK_MONTHS=6
